{
  "Inlines references": {
    "input": {
      "$id": "id.json",
      "$schema": "https://json-schema.org/draft-07/schema",
      "type": "object",
      "properties": {
        "foos": {
          "description": "Foos",
          "type": "array",
          "items": {
            "$ref": "#/definitions/foo"
          }
        }
      },
      "definitions": {
        "foo": {
          "description": "Foo",
          "type": "string"
        }
      }
    },
    "expected_output": {
      "$id": "id.json",
      "$schema": "https://json-schema.org/draft-07/schema",
      "type": "object",
      "properties": {
        "foos": {
          "description": "Foos",
          "type": "array",
          "items": {
            "description": "Foo",
            "type": "string"
          }
        }
      }
    }
  },
  "Rewrites singleton pattern properties": {
    "input": {
      "properties": {
        "foos": {
          "description": "Description",
          "type": "object",
          "patternProperties": {
            "^.+$": {
              "type": "string"
            }
          },
          "additionalProperties": false
        }
      }
    },
    "expected_output": {
      "properties": {
        "foos": {
          "description": "Description",
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      }
    }
  }
}
