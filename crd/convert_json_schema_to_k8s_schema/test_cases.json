{
  "Inlines references": {
    "input": {
      "$schema": "https://json-schema.org/draft-07/schema",
      "type": "object",
      "properties": {
        "foos": {
          "description": "Foos",
          "type": "array",
          "items": {
            "$ref": "#/definitions/foo"
          }
        }
      },
      "definitions": {
        "foo": {
          "description": "Foo",
          "type": "string"
        }
      }
    },
    "expected_output": {
      "$schema": "https://json-schema.org/draft-07/schema",
      "type": "object",
      "properties": {
        "foos": {
          "description": "Foos",
          "type": "array",
          "items": {
            "description": "Foo",
            "type": "string"
          }
        }
      }
    }
  },
  "Removes disallowed `$id`": {
    "input": {
      "$id": "id.json",
      "type": "object"
    },
    "expected_output": {
      "type": "object"
    }
  },
  "Removes disallowed `deprecated`": {
    "input": {
      "description": "Foo",
      "type": "object",
      "deprecated": false,
      "properties": {
        "bar": {
          "description": "Bar",
          "type": "string",
          "deprecated": true
        }
      }
    },
    "expected_output": {
      "description": "Foo",
      "type": "object",
      "properties": {
        "bar": {
          "description": "Bar",
          "type": "string"
        }
      }
    }
  },
  "Removes disallowed `uniqueItems`": {
    "input": {
      "description": "Foo",
      "type": "object",
      "properties": {
        "bar": {
          "description": "Bar",
          "type": "array",
          "uniqueItems": false
        },
        "baz": {
          "description": "Baz",
          "type": "array",
          "uniqueItems": true
        }
      }
    },
    "expected_output": {
      "description": "Foo",
      "type": "object",
      "properties": {
        "bar": {
          "description": "Bar",
          "type": "array",
          "uniqueItems": false
        },
        "baz": {
          "description": "Baz",
          "type": "array"
        }
      }
    }
  },
  "Removes disallowed `additionalProperties` next to `properties`": {
    "input": {
      "description": "Foo",
      "type": "object",
      "properties": {
        "bar": {
          "description": "Bar",
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "expected_output": {
      "description": "Foo",
      "type": "object",
      "properties": {
        "bar": {
          "description": "Bar",
          "type": "string"
        }
      }
    }
  },
  "Rewrites singleton `patternProperties`": {
    "input": {
      "description": "Foo",
      "type": "object",
      "patternProperties": {
        "^.+$": {
          "description": "Bar",
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "expected_output": {
      "description": "Foo",
      "type": "object",
      "additionalProperties": {
        "description": "Bar",
        "type": "string"
      }
    }
  },
  "Rewrites wild card `patternProperties`": {
    "input": {
      "description": "Foo",
      "type": "object",
      "properties": {
        "bar": {
          "description": "Bar",
          "type": "string"
        }
      },
      "patternProperties": { "^x-": {} },
      "additionalProperties": false
    },
    "expected_output": {
      "description": "Foo",
      "type": "object",
      "properties": {
        "bar": {
          "description": "Bar",
          "type": "string"
        }
      },
      "x-kubernetes-preserve-unknown-fields": true
    }
  }
}
