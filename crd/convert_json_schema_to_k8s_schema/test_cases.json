{
  "Inlines references": {
    "input": {
      "$id": "id.json",
      "$schema": "https://json-schema.org/draft-07/schema",
      "type": "object",
      "properties": {
        "foos": {
          "description": "Foos",
          "type": "array",
          "items": {
            "$ref": "#/definitions/foo"
          }
        }
      },
      "definitions": {
        "foo": {
          "description": "Foo",
          "type": "string"
        }
      }
    },
    "expected_output": {
      "$id": "id.json",
      "$schema": "https://json-schema.org/draft-07/schema",
      "type": "object",
      "properties": {
        "foos": {
          "description": "Foos",
          "type": "array",
          "items": {
            "description": "Foo",
            "type": "string"
          }
        }
      }
    }
  },
  "Removes disallowed `additionalProperties` next to `properties`": {
    "input": {
      "description": "Foo",
      "type": "object",
      "properties": {
        "bar": {
          "description": "Bar",
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "expected_output": {
      "description": "Foo",
      "type": "object",
      "properties": {
        "bar": {
          "description": "Bar",
          "type": "string"
        }
      }
    }
  },
  "Rewrites singleton `patternProperties`": {
    "input": {
      "description": "Foo",
      "type": "object",
      "patternProperties": {
        "^.+$": {
          "description": "Bar",
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "expected_output": {
      "description": "Foo",
      "type": "object",
      "additionalProperties": {
        "description": "Bar",
        "type": "string"
      }
    }
  }
}
